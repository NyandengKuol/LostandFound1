{
  "version": 2,
  "installCommand": "cd server && npm install && cd ../Project1 && npm install",
  "buildCommand": "cd Project1 && npm run build",
  "outputDirectory": "Project1/dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
